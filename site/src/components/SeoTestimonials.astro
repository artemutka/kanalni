---
import type { ServiceArea } from '../data/serviceAreas';
import type { ServiceType } from '../data/serviceTypes';
import { getReviewsForPage, reviews } from '../data/seoContent';
import { Icon } from 'astro-icon/components';

interface Props {
  area: ServiceArea;
  service?: ServiceType;
}

const { area, service } = Astro.props;

// Get the 3 most relevant reviews for this page
const pageReviews = getReviewsForPage(area.slug, service?.slug, 3);

// Calculate aggregate rating from ALL reviews
const avgRating =
  reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length;

// Structured data for search engines
const aggregateSchema = {
  '@context': 'https://schema.org',
  '@type': 'HVACBusiness',
  name: 'Канальні',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: avgRating.toFixed(1),
    bestRating: '5',
    worstRating: '1',
    reviewCount: reviews.length,
  },
  review: pageReviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.author },
    datePublished: r.date,
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
    reviewBody: r.text,
  })),
};

/**
 * Format an ISO date string (YYYY-MM-DD) into a readable form.
 */
function formatDate(iso: string): string {
  const date = new Date(iso + 'T00:00:00');
  return date.toLocaleDateString('uk-UA', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section class="mt-16">
  <h2 class="font-display text-2xl text-stone-900">Відгуки клієнтів</h2>

  {/* Aggregate summary */}
  <div class="mt-4 flex items-center gap-2">
    <div class="flex items-center gap-0.5">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          viewBox="0 0 24 24" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          class:list={[
            'size-5',
            i < Math.round(avgRating)
              ? 'fill-[#fbbf24] text-[#fbbf24]'
              : 'fill-stone-200 text-stone-200',
          ]}
        >
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
      ))}
    </div>
    <span class="text-sm font-semibold text-stone-800">
      {avgRating.toFixed(1)} з 5
    </span>
    <span class="text-sm text-stone-500">
      на основі {reviews.length} відгуків
    </span>
  </div>

  {/* Individual review cards */}
  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {pageReviews.map((review) => {
      const fullStars = Math.floor(review.rating);
      return (
        <div class="rounded-xl border border-stone-200/60 bg-white p-6">
          {/* Star rating */}
          <div class="flex items-center gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                viewBox="0 0 24 24" 
                stroke="currentColor" 
                stroke-width="2" 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                class:list={[
                  'size-4',
                  i < fullStars
                    ? 'fill-[#fbbf24] text-[#fbbf24]'
                    : 'fill-stone-200 text-stone-200',
                ]}
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            ))}
          </div>

          {/* Review text */}
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            {review.text}
          </p>

          {/* Author and date */}
          <div class="mt-5 border-t border-slate-100 pt-5 flex items-center gap-3">
            {review.avatar ? (
              <img src={review.avatar} alt={review.author} class="w-10 h-10 rounded-full object-cover bg-slate-100 ring-2 ring-slate-50" loading="lazy" />
            ) : (
              <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 font-display font-medium ring-2 ring-slate-50">
                {review.author.charAt(0)}
              </div>
            )}
            <div>
              <span class="block text-sm font-semibold text-slate-900">
                {review.author}
              </span>
              <span class="block text-xs text-slate-400 mt-0.5">
                {formatDate(review.date)} {review.source && `• ${review.source}`}
              </span>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

{/* AggregateRating + Review schema */}
<script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />


