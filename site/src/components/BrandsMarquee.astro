---
import { Icon } from 'astro-icon/components';

const brands = [
  { name: 'Daikin', logo: 'Daikin' },
  { name: 'Mitsubishi Electric', logo: 'Mitsubishi' },
  { name: 'Gree', logo: 'GREE' },
  { name: 'Cooper&Hunter', logo: 'C&H' },
  { name: 'Toshiba', logo: 'TOSHIBA' },
  { name: 'Neoclima', logo: 'Neoclima' },
  { name: 'Panasonic', logo: 'Panasonic' },
  { name: 'Midea', logo: 'Midea' },
];
---

<section class="border-y border-stone-200/60 bg-stone-50 py-12 lg:py-16 overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="text-center mb-8">
      <h2 class="text-sm font-bold uppercase tracking-widest text-stone-400">
        Працюємо з провідними світовими брендами
      </h2>
    </div>
    
    <!-- Marquee Container -->
    <div class="relative flex w-full flex-col items-center justify-center overflow-hidden bg-stone-50">
      
      <!-- Gradient Fades for edges -->
      <div class="absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-stone-50 to-transparent sm:w-32"></div>
      <div class="absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-stone-50 to-transparent sm:w-32"></div>

      <!-- Scrolling Track -->
      <div class="flex w-fit animate-marquee gap-8 sm:gap-16">
        <!-- First set of brands -->
        {brands.map((brand) => (
          <div class="flex items-center justify-center grayscale transition-all hover:grayscale-0 opacity-60 hover:opacity-100">
             <span class="font-display text-2xl sm:text-3xl font-bold text-stone-800 tracking-tight whitespace-nowrap">
               {brand.logo}
             </span>
          </div>
        ))}
        <!-- Duplicated second set for seamless looping -->
        {brands.map((brand) => (
          <div class="flex items-center justify-center grayscale transition-all hover:grayscale-0 opacity-60 hover:opacity-100">
             <span class="font-display text-2xl sm:text-3xl font-bold text-stone-800 tracking-tight whitespace-nowrap">
               {brand.logo}
             </span>
          </div>
        ))}
        <!-- Duplicated third set just in case of ultra-wide screens -->
        {brands.map((brand) => (
          <div class="flex items-center justify-center grayscale transition-all hover:grayscale-0 opacity-60 hover:opacity-100">
             <span class="font-display text-2xl sm:text-3xl font-bold text-stone-800 tracking-tight whitespace-nowrap">
               {brand.logo}
             </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Tailwind arbitrary value animation override inside global.css is cleaner, 
     but we can do a quick keyframe here for the marquee */
  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      /* Move left by 33.33% because we have 3 identical sets of brands */
      transform: translateX(-33.3333%);
    }
  }
  
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  
  /* Pause on hover */
  .animate-marquee:hover {
    animation-play-state: paused;
  }
</style>
