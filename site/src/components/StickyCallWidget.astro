---
import { Icon } from 'astro-icon/components';

// Generate hours (09 to 18) for business hours
const hours = Array.from({ length: 10 }, (_, i) => (i + 9).toString().padStart(2, '0'));
// Generate minutes (00, 15, 30, 45)
const minutes = ['00', '15', '30', '45'];
---

<div
  id="sticky-callback-widget"
  class="fixed bottom-0 left-0 z-50 w-full translate-y-full border-t border-slate-200 bg-white/95 backdrop-blur-lg shadow-[0_-10px_40px_-5px_rgba(0,0,0,0.1)] transition-transform duration-500 ease-out"
>
  <div class="relative mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-5 pt-10 pb-5 sm:py-6 lg:px-8">
    
    <div id="callback-form-container" class="flex w-full flex-col items-center justify-center gap-5 lg:flex-row lg:gap-8">
      
      {/* Form Section */}
      <form id="callback-form" class="flex w-full flex-col items-center justify-center gap-5 lg:w-auto lg:flex-row">
        
        {/* Dynamic Text and Selectors */}
        <div class="flex flex-col items-center justify-center gap-3 text-[16px] font-medium text-slate-600 sm:flex-row sm:flex-wrap sm:text-[17px]">
          
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span>Хочете, зателефонуємо Вам</span>
            
            {/* Day Picker */}
            <select
              id="day-select"
              name="day"
              class="h-11 sm:h-12 cursor-pointer appearance-none rounded-xl border border-brand-200 bg-brand-50 px-4 py-2 pr-8 text-center font-bold text-brand-700 transition-colors hover:bg-brand-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
              required
            >
              <!-- Options populated via JS -->
              <option value="today">сьогодні</option>
              <option value="tomorrow">завтра</option>
            </select>
          </div>

          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="mx-1">рівно о:</span>

            {/* Time Picker */}
            <div class="flex items-center gap-1.5">
              <select
                name="time-hour"
                class="h-11 sm:h-12 cursor-pointer appearance-none rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 pr-7 text-center font-bold text-slate-800 transition-colors hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
                required
              >
                {hours.map(hour => <option value={hour} selected={hour === '10'}>{hour}</option>)}
              </select>
              <span class="font-bold text-slate-400">:</span>
              <select
                name="time-minute"
                class="h-11 sm:h-12 cursor-pointer appearance-none rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 pr-7 text-center font-bold text-slate-800 transition-colors hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
                required
              >
                {minutes.map(minute => <option value={minute} selected={minute === '00'}>{minute}</option>)}
              </select>
            </div>
          </div>
        </div>

        {/* Action Section */}
        <div class="flex w-full max-w-sm flex-col items-center gap-3 sm:flex-row lg:w-auto lg:max-w-none">
          {/* Phone Input with Validation */}
          <input
            type="tel"
            name="phone"
            id="callback-phone-input"
            placeholder="050 123 45 67"
            class="h-11 sm:h-12 w-full flex-1 rounded-xl border border-slate-300 bg-white px-4 text-[16px] sm:text-[17px] text-slate-800 placeholder:text-slate-400 transition-shadow focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
            required
          />

          {/* Submit Button */}
          <button
            type="submit"
            class="h-11 sm:h-12 w-full flex-shrink-0 rounded-xl bg-brand-500 px-8 text-[16px] sm:text-[17px] font-semibold text-white shadow-sm transition-all hover:bg-brand-600 hover:shadow-md hover:shadow-brand-500/20 active:scale-95 sm:w-auto"
          >
            Чекаю на дзвінок
          </button>
        </div>
      </form>
    </div>

    {/* Success Message */}
    <div id="callback-success" class="hidden flex w-full flex-col items-center justify-center gap-3 py-5 sm:flex-row">
       <Icon name="lucide:check-circle-2" class="size-8 text-brand-500" />
       <span class="text-xl font-medium text-slate-800">Дякуємо! Ваш запит прийнято, очікуйте на дзвінок.</span>
    </div>

    {/* Close Button */}
    <button
      type="button"
      id="close-callback-widget"
      class="absolute right-3 top-3 rounded-full p-2 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-600"
      aria-label="Close"
    >
      <Icon name="lucide:x" class="size-6" />
    </button>
  </div>
</div>

<style>
  /* Custom select arrow overrides */
  select[name="day"] {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%230ea5e9' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.75rem center;
    background-repeat: no-repeat;
    background-size: 1.25em 1.25em;
  }
  
  select[name="time-hour"], select[name="time-minute"] {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%23475569' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.25em 1.25em;
  }
</style>

<script>
  // Dynamic day options initialization
  const initDaySelect = () => {
    const daySelect = document.getElementById('day-select') as HTMLSelectElement | null;
    if (!daySelect) return;
    
    const now = new Date();
    const currentHour = now.getHours();
    const daysUkr = ['в неділю', 'в понеділок', 'в вівторок', 'в середу', 'в четвер', 'в п\'ятницю', 'в суботу'];
    
    daySelect.innerHTML = '';
    
    // Logic: if working hours (before 18:00), offer today
    if (currentHour < 18) {
      daySelect.add(new Option('сьогодні', 'today'));
      daySelect.add(new Option('завтра', 'tomorrow'));
    } else {
      // If after 18:00, offer tomorrow and the day after
      daySelect.add(new Option('завтра', 'tomorrow'));
      
      const nextDate = new Date();
      nextDate.setDate(now.getDate() + 2);
      daySelect.add(new Option(daysUkr[nextDate.getDay()], 'day_after_tomorrow'));
    }
  };

  // Widget initialization
  const initWidget = () => {
    initDaySelect();
    
    const widget = document.getElementById('sticky-callback-widget');
    if (!widget) return;

    // Show widget after delay if not closed
    setTimeout(() => {
      if (!sessionStorage.getItem('callback-widget-closed')) {
        widget.classList.remove('translate-y-full');
      }
    }, 2000);

    // Handle close button
    const closeBtn = document.getElementById('close-callback-widget');
    closeBtn?.addEventListener('click', () => {
      widget.classList.add('translate-y-full');
      sessionStorage.setItem('callback-widget-closed', 'true');
    });

    // Form Submission & Validation
    const form = document.getElementById('callback-form') as HTMLFormElement;
    const phoneInput = document.getElementById('callback-phone-input') as HTMLInputElement;

    if (form && phoneInput) {
      // Clear custom error when user starts typing
      phoneInput.addEventListener('input', () => {
        phoneInput.setCustomValidity('');
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Strip everything except digits
        const digitsOnly = phoneInput.value.replace(/\D/g, '');
        
        // Validate Ukrainian format (10 digits starting with 0, or 12 digits starting with 380)
        let isValid = false;
        if (digitsOnly.length === 10 && digitsOnly.startsWith('0')) {
          isValid = true;
        } else if (digitsOnly.length === 12 && digitsOnly.startsWith('380')) {
          isValid = true;
        }

        if (!isValid) {
          phoneInput.setCustomValidity('Введіть коректний український номер (рівно 10 цифр, наприклад: 050 123 45 67)');
          phoneInput.reportValidity();
          return;
        }

        // Prepare data for API
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = 'Відправка...';
        submitBtn.disabled = true;

        try {
          const formData = new FormData(form);
          const day = formData.get('day');
          const timeHour = formData.get('time-hour');
          const timeMinute = formData.get('time-minute');
          const phone = formData.get('phone');

          const payload = new FormData();
          payload.append('source', 'Липкий віджет (Передзвоніть мені)');
          payload.append('phone', phone as string);
          payload.append('message', `Клієнт просить зателефонувати йому: ${day} о ${timeHour}:${timeMinute}`);

          const response = await fetch('/api/submit', {
            method: 'POST',
            body: payload
          });

          if (response.ok) {
            document.getElementById('callback-form-container')?.classList.add('hidden');
            document.getElementById('callback-success')?.classList.remove('hidden');
          } else {
            alert('Виникла помилка при відправці. Спробуйте ще раз або зателефонуйте нам безпосередньо.');
            submitBtn.innerText = originalText;
            submitBtn.disabled = false;
          }
        } catch (error) {
          alert('Помилка з\'єднання. Перевірте підключення до інтернету.');
          submitBtn.innerText = originalText;
          submitBtn.disabled = false;
        }
      });
    }
  };

  // Run on load
  initWidget();
</script>
