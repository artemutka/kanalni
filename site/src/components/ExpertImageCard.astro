---
import { Icon } from 'astro-icon/components';
---

<!-- Real-world Image (E-E-A-T Experience Signal) -->
<div class="mt-20 lg:mt-0 relative animate-fade-up stagger-2">
  <!-- Abstract Decoration Background (Provides structure) -->
  <div class="relative w-full aspect-[4/5] sm:aspect-[3/4] lg:aspect-[4/5] rounded-3xl bg-slate-100 shadow-xl ring-1 ring-slate-900/10 flex items-end justify-center">
    
    <img 
      src="/images/installer-expert.png" 
      alt="Експертний монтаж вентиляції та кондиціювання" 
      class="absolute bottom-0 w-[145%] max-w-none sm:w-[125%] lg:w-[145%] object-contain object-bottom drop-shadow-2xl z-10 pointer-events-none"
      loading="lazy"
    />
  </div>
  
  <!-- Trust Badge -->
  <div class="absolute bottom-6 -left-2 sm:left-4 rounded-2xl bg-white p-4 shadow-xl ring-1 ring-slate-900/5 animate-fade-up stagger-3 flex items-center gap-4 z-20">
      <div class="flex size-12 items-center justify-center rounded-full bg-green-50 text-green-600">
        <Icon name="lucide:shield-check" class="size-6" />
      </div>
      <div>
        <p class="text-sm font-bold text-slate-900 m-0 leading-tight">Експертний підбір</p>
        <p class="text-xs text-slate-500 m-0 mt-0.5">Конкурентний кошторис за 24 год</p>
      </div>
  </div>
</div>
