---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;

// Filter out h1 (usually the post title) and mostly keep h2 and h3
const tocHeadings = headings.filter((h) => h.depth > 1 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <nav class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 hidden lg:block">
    <h3 class="font-display text-sm uppercase tracking-wider text-stone-900 mb-4">
      Зміст статті
    </h3>
    <ul class="space-y-2.5 text-sm">
      {tocHeadings.map((heading) => (
        <li class={heading.depth === 3 ? "pl-4" : ""}>
          <a
            href={`#${heading.slug}`}
            class="text-stone-500 hover:text-brand-600 transition-colors block line-clamp-2"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

{/* Mobile Table of Contents */}
{tocHeadings.length > 0 && (
  <details class="lg:hidden mb-10 group rounded-xl border border-stone-200 bg-stone-50 overflow-hidden">
    <summary class="flex cursor-pointer items-center justify-between px-5 py-4 font-display text-sm font-medium text-stone-900 hover:bg-stone-100 transition-colors">
      <span>Зміст статті</span>
      <span class="transition-transform duration-200 group-open:rotate-180">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </span>
    </summary>
    <div class="border-t border-stone-200 bg-white px-5 py-4">
      <ul class="space-y-3 text-sm">
        {tocHeadings.map((heading) => (
          <li class={heading.depth === 3 ? "pl-4" : ""}>
            <a
              href={`#${heading.slug}`}
              class="text-stone-600 hover:text-brand-600 transition-colors block"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </details>
)}
