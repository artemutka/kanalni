---
import { Icon } from 'astro-icon/components';
---

<!-- Calculator Widget -->
<section class="relative overflow-hidden bg-brand-950 py-16 lg:py-24" id="calculator">
  <!-- Aesthetic backgrounds -->
  <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-brand-900 to-transparent opacity-50 mix-blend-overlay"></div>
  <div class="absolute -right-40 -top-40 h-96 w-96 rounded-full bg-brand-500/20 blur-[100px]"></div>

  <div class="relative mx-auto max-w-4xl px-5 lg:px-8">
    
    <!-- Heading -->
    <div class="mb-10 text-center sm:mb-12">
      <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
        Орієнтовний калькулятор
      </h2>
      <p class="mt-4 text-stone-300">
        Дізнайтеся приблизний бюджет на систему канального кондиціювання 
        для вашого об'єкта всього за пару кліків.
      </p>
    </div>

    <!-- The Glassmorphic Calculator Card -->
    <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl shadow-2xl sm:p-10">
      
      <!-- 1. Area Slider -->
      <div class="mb-10">
        <label for="area-slider" class="mb-4 flex items-center justify-between">
          <span class="text-sm font-medium uppercase tracking-wider text-brand-300">Площа приміщення</span>
          <span class="font-display text-2xl font-bold text-white" id="area-display">100 м²</span>
        </label>
        
        <div class="relative py-4">
          <input 
            type="range" 
            id="area-slider" 
            min="30" 
            max="400" 
            step="5" 
            value="100" 
            class="w-full cursor-pointer appearance-none rounded-full bg-brand-900/50 h-2 outline-none focus:outline-none focus:ring-2 focus:ring-brand-500/50"
          >
          <div class="mt-3 flex justify-between text-xs font-medium text-stone-500">
            <span>30 м²</span>
            <span>400 м²</span>
          </div>
        </div>
      </div>

      <!-- 2. System Type Selection -->
      <div class="mb-12">
        <span class="mb-4 block text-sm font-medium uppercase tracking-wider text-brand-300">Клас обладнання</span>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3" id="system-type-group">
          
          <button type="button" data-multiplier="50" class="calc-btn group relative flex flex-col items-start gap-2 rounded-xl border-2 border-brand-500 bg-brand-500/10 p-4 text-left transition-all hover:bg-white/10 border-brand-500 bg-brand-500/20 shadow-[0_0_15px_rgba(14,165,233,0.3)]">
            <span class="font-semibold text-white">Базовий</span>
            <span class="text-xs text-stone-400">Надійні кондиціонери (стандарт Midea, Sinclair)</span>
          </button>
          
          <button type="button" data-multiplier="75" class="calc-btn group relative flex flex-col items-start gap-2 rounded-xl border-2 border-white/10 bg-transparent p-4 text-left transition-all hover:bg-white/10">
            <span class="font-semibold text-white">Оптимальний</span>
            <span class="text-xs text-stone-400">Висока ефективність (Cooper&Hunter, Gree)</span>
          </button>
          
          <button type="button" data-multiplier="110" class="calc-btn group relative flex flex-col items-start gap-2 rounded-xl border-2 border-white/10 bg-transparent p-4 text-left transition-all hover:bg-white/10 sm:col-span-2 lg:col-span-1">
            <span class="font-semibold text-white">Преміум</span>
            <span class="text-xs text-stone-400">Топові японські бренди (Daikin, Mitsubishi)</span>
          </button>
          
        </div>
      </div>

      <!-- 3. Result & CTA -->
      <div class="flex flex-col items-center justify-between gap-6 rounded-2xl bg-brand-900/50 p-6 sm:flex-row sm:p-8 border border-white/5">
        <div>
          <span class="block text-sm font-medium text-stone-400">Орієнтовний бюджет під ключ:</span>
          <div class="mt-1 flex items-baseline gap-2">
            <span class="font-display text-4xl font-bold tracking-tight text-white lg:text-5xl" id="budget-display">
              $5,000
            </span>
            <span class="text-lg text-stone-400">± 15%</span>
          </div>
          <p class="mt-2 max-w-sm text-xs text-stone-500 leading-snug">
            Враховує вартість внутрішнього/зовнішнього блоків, повітропроводів, решіток та монтажних робіт.
          </p>
        </div>
        
        <a 
          href="/contact/" 
          id="calc-cta"
          class="inline-flex shrink-0 items-center justify-center gap-2 rounded-xl bg-brand-500 px-8 py-4 text-sm font-bold text-white shadow-[0_0_20px_rgba(14,165,233,0.3)] transition-all hover:-translate-y-0.5 hover:bg-brand-400 hover:shadow-[0_0_30px_rgba(14,165,233,0.4)] w-full sm:w-auto text-center"
        >
          Отримати точний прорахунок
          <Icon name="lucide:arrow-right" class="size-4" />
        </a>
      </div>

    </div>
  </div>
</section>

<!-- Custom Styles for Slider Thumb -->
<style>
  input[type=range] {
    -webkit-appearance: none;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    height: 24px;
    width: 24px;
    border-radius: 50%;
    background: #0ea5e9;
    cursor: pointer;
    margin-top: -8px; /* You need to specify a margin in Chrome, but in Firefox and IE it is automatic */
    box-shadow: 0 0 10px rgba(14, 165, 233, 0.5);
    border: 3px solid #fff;
    transition: transform 0.1s;
  }
  input[type=range]::-webkit-slider-thumb:hover {
    transform: scale(1.1);
  }
  input[type=range]::-webkit-slider-runnable-track {
    width: 100%;
    height: 8px;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }
</style>

<!-- Logic -->
<script>
  // DOM Elements
  const slider = document.getElementById('area-slider') as HTMLInputElement;
  const areaDisplay = document.getElementById('area-display');
  const budgetDisplay = document.getElementById('budget-display');
  const buttons = document.querySelectorAll('.calc-btn');
  const cta = document.getElementById('calc-cta') as HTMLAnchorElement;

  if (slider && areaDisplay && budgetDisplay && buttons.length > 0 && cta) {
    let currentArea = parseInt(slider.value);
    let currentMultiplier = 50; // default multiplier (Базовий)
    
    // Formatter for currency
    const formatCurrency = (amount: number) => {
      // Using USD format as an example standard for HVAC quotes, change to UAH if needed
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(amount);
    };

    // Calculate and update DOM
    const updateCalculator = () => {
      // Logic: Area * Base rate multiplier
      // *This is a dummy formula. The real business usually has a non-linear formula, 
      // but a linear multiplier is good for "rough estimates".*
      const estimatedCost = currentArea * currentMultiplier;
      
      // Update UI
      areaDisplay.innerText = `${currentArea} м²`;
      budgetDisplay.innerText = formatCurrency(estimatedCost);

      // Update CTA Link to pre-fill the contact form
      const searchParams = new URLSearchParams();
      searchParams.set('area', currentArea.toString());
      searchParams.set('source', 'Калькулятор');
      cta.href = `/contact/?${searchParams.toString()}`;
    };

    // Slider Event
    slider.addEventListener('input', (e) => {
      currentArea = parseInt((e.target as HTMLInputElement).value);
      updateCalculator();
    });

    // Buttons Event
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset all buttons style to inactive
        buttons.forEach(b => {
          b.classList.remove('border-brand-500', 'bg-brand-500/20', 'shadow-[0_0_15px_rgba(14,165,233,0.3)]');
          b.classList.add('border-white/10', 'bg-transparent');
        });

        // Set clicked button to active
        btn.classList.remove('border-white/10', 'bg-transparent');
        btn.classList.add('border-brand-500', 'bg-brand-500/20', 'shadow-[0_0_15px_rgba(14,165,233,0.3)]');

        // Extract multiplier and update
        currentMultiplier = parseInt(btn.getAttribute('data-multiplier') || '50');
        updateCalculator();
      });
    });

    // Initial run
    updateCalculator();
  }
</script>
