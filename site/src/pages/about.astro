---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../data/business';
import { serviceAreas } from '../data/serviceAreas';
import { areaUrl, contactUrl } from '../lib/urls';

const years = yearsInBusiness();
---

<BaseLayout
  title={`Про сервіс ${business.name}`}
  description={`${business.name} — сервіс підбору перевірених підрядників з канального кондиціювання в ${business.address.city}. Безкоштовні консультації та порівняння пропозицій.`}
>
  <Breadcrumbs crumbs={[{ label: 'Про нас' }]} />

  <!-- ============ HEADER ============ -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="max-w-3xl animate-fade-up">
        <h1 class="font-display text-4xl text-brand-900 sm:text-5xl">
          Про сервіс {business.name}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-stone-600">
          Ми допомагаємо мешканцям {business.address.city} знайти перевірених підрядників
          для проектування та монтажу канальних систем кондиціювання.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ OUR STORY ============ -->
  <section class="pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="prose-editorial max-w-3xl">
        <h2>Як працює наш сервіс</h2>
        <p>
          {business.name} — це платформа, яка з'єднує клієнтів з перевіреними підрядниками
          з канального кондиціювання в {business.address.city} та околицях.
        </p>
        <p>
          Ми не виконуємо монтаж самостійно. Натомість ми ретельно відбираємо та перевіряємо
          спеціалістів з канальних систем, щоб ви могли порівняти пропозиції та обрати
          найкращий варіант для вашого проекту.
        </p>
        <p class="mt-2 text-stone-600">
          Заповніть форму з описом вашого об'єкта, і протягом 24 годин ви отримаєте
          попередні цінові пропозиції від місцевих підрядників. Порівняйте ціни, умови та відгуки — і оберіть
          того, хто підходить найкраще. Наш сервіс повністю безкоштовний для клієнтів.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ TRUST SIGNALS ============ -->
  <section class="bg-stone-100 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="text-center font-display text-3xl text-brand-900">
        Чому нам довіряють
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            icon: 'lucide:shield-check',
            title: 'Перевірені підрядники',
            detail: 'Кожен підрядник проходить перевірку якості та наявності відповідних дозволів.',
          },
          {
            icon: 'lucide:gift',
            title: 'Безкоштовна консультація',
            detail: 'Наш сервіс повністю безкоштовний для клієнтів. Ви нічим не ризикуєте.',
          },
          {
            icon: 'lucide:bar-chart-3',
            title: 'Порівняння пропозицій',
            detail: 'Отримайте до 3 пропозицій від різних підрядників та оберіть найкращу.',
          },
          {
            icon: 'lucide:map-pin',
            title: `Локальна експертиза`,
            detail: `Працюємо виключно в ${business.address.city} та знаємо місцевий ринок.`,
          },
        ].map((item, i) => (
          <div class={`rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${i + 1}`}>
            <div class="flex size-12 items-center justify-center rounded-lg bg-brand-50 text-brand-700">
              <Icon name={item.icon} class="size-6" />
            </div>
            <h3 class="mt-4 font-display text-lg text-brand-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ AREAS WE COVER ============ -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="text-center font-display text-3xl text-brand-900">
        Райони обслуговування
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-stone-600">
        Працюємо з підрядниками по всьому {business.address.city} та навколишніх районах.
      </p>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area) => (
          <a
            href={areaUrl(area.slug)}
            class="card-hover flex items-center gap-3 rounded-xl border border-stone-200 bg-white px-5 py-4 transition-colors"
          >
            <Icon name="lucide:map-pin" class="size-5 shrink-0 text-brand-600" />
            <div>
              <span class="font-medium text-brand-900">{area.name}</span>
              <span class="block text-xs text-stone-500">{area.county}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="bg-brand-900">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white">Потрібна консультація?</h2>
          <p class="mt-2 text-brand-200">
            Заповніть форму і отримайте пропозицію чи декілька від перевірених підрядників. Безкоштовно.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:bg-brand-400 hover:shadow-brand-500/25"
          >
            <Icon name="lucide:message-square" class="size-5" />
            Отримати консультацію
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
