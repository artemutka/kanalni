---
import { business, yearsInBusiness } from '../../../data/business';
import { serviceTypes } from '../../../data/serviceTypes';
import { serviceAreas, getNearbyAreas } from '../../../data/serviceAreas';
import type { ServiceType } from '../../../data/serviceTypes';
import type { ServiceArea } from '../../../data/serviceAreas';
import { serviceUrl, areaUrl, comboUrl, contactUrl } from '../../../lib/urls';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SeoFaq from '../../../components/SeoFaq.astro';
import SeoRelatedLinks from '../../../components/SeoRelatedLinks.astro';
import SeoServiceAreas from '../../../components/SeoServiceAreas.astro';
import SeoTestimonials from '../../../components/SeoTestimonials.astro';
import { Icon } from 'astro-icon/components';

export function getStaticPaths() {
  const paths = [];
  for (const area of serviceAreas) {
    for (const service of serviceTypes) {
      paths.push({
        params: { area: area.slug, service: service.slug },
        props: { area, service },
      });
    }
  }
  return paths;
}

interface Props {
  area: ServiceArea;
  service: ServiceType;
}

const { area, service } = Astro.props;
const years = yearsInBusiness();
const nearbyAreas = getNearbyAreas(area.slug);
const nearbyNames = nearbyAreas.map((a) => a.name).join(', ');

const pageTitle = `${service.name} ${area.name} | ${business.name}`;
const pageDescription = `Потрібна ${service.name.toLowerCase()} в ${area.name}? ${business.name} підбере перевіреного підрядника. Безкоштовна консультація.`;

// Service + LocalBusiness JSON-LD schema
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${business.siteUrl}${comboUrl(area.slug, service.slug)}#service`,
      name: `${service.name} in ${area.name}`,
      description: `${service.description} Serving ${area.name}, ${area.county} and surrounding communities.`,
      provider: {
        '@type': 'HVACBusiness',
        '@id': `${business.siteUrl}/#business`,
        name: business.name,
        telephone: business.phone,
        url: business.siteUrl,
        address: {
          '@type': 'PostalAddress',
          addressLocality: business.address.city,
          addressRegion: business.address.state,
          postalCode: business.address.zip,
          addressCountry: business.address.country,
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: business.coordinates.lat,
          longitude: business.coordinates.lng,
        },
        foundingDate: `${business.foundedYear}`,
      },
      areaServed: [
        {
          '@type': 'City',
          name: area.name,
          containedInPlace: {
            '@type': 'AdministrativeArea',
            name: area.county,
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Головна',
          item: business.siteUrl,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Послуги',
          item: `${business.siteUrl}/services/`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: area.name,
          item: `${business.siteUrl}${areaUrl(area.slug)}`,
        },
        {
          '@type': 'ListItem',
          position: 4,
          name: service.name,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={`${business.siteUrl}${comboUrl(area.slug, service.slug)}`}
  schema={schema}
>
  <Breadcrumbs
    crumbs={[
      { label: 'Послуги', href: '/services/' },
      { label: area.name, href: areaUrl(area.slug) },
      { label: service.name },
    ]}
  />

  <article class="mx-auto max-w-7xl px-5 lg:px-8">
    <!-- ============ HERO / H1 ============ -->
    <header class="relative overflow-hidden bg-slate-900 rounded-3xl mt-4 lg:mt-8 mb-8 py-12 px-6 lg:p-16 shadow-xl">
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent z-10" />
      <img
        src={service.image}
        alt={`${service.name} ${area.name}`}
        class="absolute inset-0 h-full w-full object-cover opacity-30 mix-blend-luminosity"
        width="2048"
        height="1024"
        loading="eager"
      />
      
      <div class="relative z-20 mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-3 text-brand-400 justify-center">
          <Icon name={service.icon} class="size-8" />
          <span class="text-sm font-semibold uppercase tracking-wider text-brand-300">
            {service.name}
          </span>
        </div>
        <h1 class="mt-6 font-display text-4xl text-white sm:text-5xl lg:text-6xl tracking-tight">
          {service.name} {area.name}
        </h1>
        <p class="mt-6 text-lg md:text-xl font-light text-slate-300 leading-relaxed">
          {pageDescription}
        </p>
      </div>
    </header>

    <!-- ============ EMERGENCY ALERT BANNER ============ -->
    {service.emergency && (
      <div class="mb-10 flex items-center gap-4 rounded-2xl border border-red-200/50 bg-red-50/50 p-6 backdrop-blur-sm">
        <div class="flex size-14 shrink-0 items-center justify-center rounded-xl bg-red-100 text-red-500">
          <Icon name="lucide:zap" class="size-6" />
        </div>
        <div>
          <p class="text-lg font-semibold text-red-700 font-display">
            Термінова {service.name} 24/7 в {area.name}
          </p>
          <p class="mt-1 text-sm text-red-600/80">
            Терміновий виклик доступний цілодобово. Залиште заявку для пріоритетного виїзду в {area.name} та околиці.
          </p>
        </div>
        <a
          href="/contact/"
          class="ml-auto hidden shrink-0 items-center gap-2 rounded-full bg-red-500 px-6 py-3 text-sm font-semibold text-white shadow transition-colors hover:bg-red-600 sm:inline-flex"
        >
          <Icon name="lucide:message-square" class="size-4" />
          Залишити заявку
        </a>
      </div>
    )}

    <!-- ============ DESCRIPTION SECTION ============ -->
    <section class="prose-editorial max-w-3xl pb-12">
      <h2>{service.name} в {area.name} та {area.county}</h2>
      <p>
        {service.description}
      </p>
      <p>
        {business.name} допомагає мешканцям {area.name} та {area.county} знайти перевірених
        підрядників для канального кондиціювання.
        {area.description}
      </p>
      {nearbyAreas.length > 0 && (
        <p>
          Окрім {area.name}, наш сервіс охоплює сусідні райони: {nearbyNames}.
          Де б ви не знаходились у регіоні, ми підберемо надійного підрядника поруч.
        </p>
      )}
    </section>

    <!-- ============ PROCESS STEPS ============ -->
    <section class="pb-20">
      <h2 class="font-display text-3xl text-slate-900 sm:text-4xl tracking-tight">
        Як працює {service.name}
      </h2>
      <p class="mt-4 max-w-2xl text-slate-500">
        Кожен проект проходить чіткий процес, щоб ви завжди знали, чого очікувати.
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {service.process.map((step, index) => (
          <div class="relative rounded-2xl bg-white p-8 ring-1 ring-slate-100 shadow-sm transition-all hover:ring-brand-500 hover:shadow-md">
            <div class="mb-6 flex size-12 items-center justify-center rounded-xl bg-brand-50 font-display text-lg font-bold text-brand-600">
              0{index + 1}
            </div>
            <h3 class="font-display text-xl text-slate-900">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-500">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ WHY CHOOSE US ============ -->
    <section class="pb-20">
      <h2 class="font-display text-3xl text-slate-900 sm:text-4xl tracking-tight">
        Чому обирають {business.name} в {area.name}?
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl bg-slate-50 p-8 text-center ring-1 ring-slate-100">
          <div class="mx-auto flex size-14 items-center justify-center rounded-xl bg-brand-100/50">
            <Icon name="lucide:shield-check" class="size-6 text-brand-600" />
          </div>
          <h3 class="mt-6 font-display text-lg text-slate-900">Перевірені підрядники</h3>
          <p class="mt-3 text-sm text-slate-500 leading-relaxed">
            Кожен підрядник проходить перевірку якості та наявності дозволів.
          </p>
        </div>

        <div class="rounded-2xl bg-slate-50 p-8 text-center ring-1 ring-slate-100">
          <div class="mx-auto flex size-14 items-center justify-center rounded-xl bg-brand-100/50">
            <Icon name="lucide:map-pin" class="size-6 text-brand-600" />
          </div>
          <h3 class="mt-6 font-display text-lg text-slate-900">Локальна експертиза</h3>
          <p class="mt-3 text-sm text-slate-500 leading-relaxed">
            Працюємо виключно в {area.name} та {area.county}. Знаємо місцевий ринок.
          </p>
        </div>

        <div class="rounded-2xl bg-slate-50 p-8 text-center ring-1 ring-slate-100">
          <div class="mx-auto flex size-14 items-center justify-center rounded-xl bg-brand-100/50">
            <Icon name="lucide:bar-chart-3" class="size-6 text-brand-600" />
          </div>
          <h3 class="mt-6 font-display text-lg text-slate-900">Порівняння пропозицій</h3>
          <p class="mt-3 text-sm text-slate-500 leading-relaxed">
            Отримайте пропозицію чи декілька та оберіть найкращу за ціною та умовами.
          </p>
        </div>

        <div class="rounded-2xl bg-slate-50 p-8 text-center ring-1 ring-slate-100">
          <div class="mx-auto flex size-14 items-center justify-center rounded-xl bg-brand-100/50">
            <Icon name="lucide:gift" class="size-6 text-brand-600" />
          </div>
          <h3 class="mt-6 font-display text-lg text-slate-900">Безкоштовно</h3>
          <p class="mt-3 text-sm text-slate-500 leading-relaxed">
            Наш сервіс повністю безкоштовний для клієнтів. Ви нічим не ризикуєте.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ CTA SECTION ============ -->
    <section class="pb-16">
      <div class="relative overflow-hidden rounded-3xl bg-slate-900 p-10 text-center lg:p-16 shadow-xl">
        <div class="absolute -top-32 -right-32 size-96 bg-brand-500 rounded-full blur-[128px] opacity-20 pointer-events-none" />
        <h2 class="relative font-display text-3xl text-white sm:text-4xl tracking-tight z-10">
          Потрібна {service.name} в {area.name}?
        </h2>
        <p class="relative mx-auto mt-6 max-w-2xl text-lg text-slate-300 font-light z-10">
          Заповніть форму і отримайте пропозицію чи декілька від перевірених підрядників. Безкоштовно.
        </p>
        <div class="relative mt-10 flex flex-wrap items-center justify-center gap-4 z-10">
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-8 py-3.5 text-sm font-medium text-white shadow-lg transition-all hover:bg-brand-400 hover:shadow-brand-500/25"
          >
            <Icon name="lucide:message-square" class="size-5" />
            Отримати консультацію
          </a>
        </div>
      </div>
    </section>

    <!-- ============ SEO COMPONENTS ============ -->
    <section class="pb-8">
      <SeoRelatedLinks area={area} service={service} />
    </section>

    <section class="pb-8">
      <SeoServiceAreas currentArea={area} service={service} />
    </section>

    <SeoTestimonials area={area} service={service} />
  </article>

  <SeoFaq area={area} service={service} />
</BaseLayout>
